{
  "expo": {
    "name": "Recipe Box",
    "slug": "recipe-box",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#FFF6EC"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.recipebox.app"
    },
    "android": {
      "package": "com.recipebox.app",
      "adaptiveIcon": {
        "foregroundImage": "./assets/icon.png",
        "backgroundColor": "#FFF6EC"
      },
      "permissions": [
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.READ_MEDIA_IMAGES",
        "android.permission.RECORD_AUDIO"
      ]
    },
    "plugins": [
      "expo-secure-store",
      "expo-sqlite",
      "expo-image-picker",
      "expo-asset"
    ],
    "extra": {
      "eas": {
        "projectId": "fe520214-8bce-4152-830e-6cda1965ba62"
      }
    },
    "owner": "gonyidan"
  }
}
